# Copy to .env.local (never commit secrets)

OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

# Local: password optional (local-dev unlock). Production: required.
ASSET_FOUNDRY_PASSWORD=
ASSET_FOUNDRY_SESSION_SECRET=

# Optional cost / limits
ASSET_FOUNDRY_DAILY_IMAGE_LIMIT=20
ASSET_FOUNDRY_DEFAULT_QUALITY=medium

# Local API
ASSET_FOUNDRY_LOCAL_STORE=true
ASSET_FOUNDRY_API_PORT=3456
